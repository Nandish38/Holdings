{
  "family": "holdings-next-fastapi",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/holdingsTaskRole",
  "containerDefinitions": [
    {
      "name": "holdings-backend",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/holdings-backend:<TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "backend-8000",
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "OPENAI_MODEL", "value": "gpt-4o-mini" },
        { "name": "PLAID_ENV", "value": "sandbox" },
        { "name": "VAULTBOARD_DB_PATH", "value": "/app/runtime/vaultboard.db" }
      ],
      "secrets": [
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:ssm:<REGION>:<ACCOUNT_ID>:parameter/holdings/OPENAI_API_KEY" },
        { "name": "PLAID_CLIENT_ID", "valueFrom": "arn:aws:ssm:<REGION>:<ACCOUNT_ID>:parameter/holdings/PLAID_CLIENT_ID" },
        { "name": "PLAID_SECRET", "valueFrom": "arn:aws:ssm:<REGION>:<ACCOUNT_ID>:parameter/holdings/PLAID_SECRET" }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/api/health', timeout=3).read()\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/holdings",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "backend"
        }
      }
    },
    {
      "name": "holdings-frontend",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/holdings-frontend:<TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "frontend-3000",
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "API_BASE_URL", "value": "http://127.0.0.1:8000" }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:3000').then(r => process.exit(r.ok ? 0 : 1)).catch(() => process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/holdings",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
}
