{
  "name": "Python 3",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py",
        "backend/main.py",
        "frontend/app/page.tsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; [ -f frontend/package.json ] && cd frontend && npm install; echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": {
    "server": "streamlit run app.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "3000": {
      "label": "Next.js frontend",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "FastAPI backend",
      "onAutoForward": "notify"
    },
    "8501": {
      "label": "Streamlit app",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    3000,
    8000,
    8501
  ]
}